<?xml version="1.0"?>
<robot name="jaka_zu12_with_camera" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="base_frame" default="base_link"/>
  <xacro:arg name="tool0_xyz" default="0 0 0"/>
  <xacro:arg name="tool0_rpy" default="0 0 0"/>
  <xacro:arg name="legacy_tcp_frame" default="jaka_tcp"/>
  <xacro:arg name="camera_parent" default="tool0"/>
  <xacro:arg name="camera_frame" default="camera_link"/>
  <xacro:arg name="camera_xyz" default="0 0 0"/>
  <xacro:arg name="camera_rpy" default="0 0 0"/>

  <link name="${base_frame}"/>

  <link name="Link_0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/base_link.STL" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/base_link.STL" /></geometry>
    </collision>
  </link>

  <link name="Link_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/1.STL" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/1.STL" /></geometry>
    </collision>
  </link>

  <link name="Link_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/2.STL" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/2.STL" /></geometry>
    </collision>
  </link>

  <link name="Link_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/3.STL" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/3.STL" /></geometry>
    </collision>
  </link>

  <link name="Link_4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/4.STL" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/4.STL" /></geometry>
    </collision>
  </link>

  <link name="Link_5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/5.STL" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/5.STL" /></geometry>
    </collision>
  </link>

  <link name="Link_6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/6.STL" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://jaka_description/meshes/jaka_zu12_meshes/6.STL" /></geometry>
    </collision>
  </link>

  <joint name="${base_frame}_to_link0" type="fixed">
    <origin xyz="0 0 0.04" rpy="0 0 0" />
    <parent link="${base_frame}"/>
    <child link="Link_0"/>
  </joint>

  <joint name="joint_1" type="continuous">
    <origin xyz="0 0 0.10265" rpy="0 0 0" />
    <parent link="Link_0" />
    <child link="Link_1" />
    <axis xyz="0 0 1" />
    <limit lower="-6.28" upper="6.28" effort="2000" velocity="2.09" />
  </joint>

  <joint name="joint_2" type="continuous">
    <origin xyz="0 0 0" rpy="1.5708 0 0" />
    <parent link="Link_1" />
    <child link="Link_2" />
    <axis xyz="0 0 1" />
    <limit lower="-1.48" upper="4.62" effort="8000" velocity="2.09" />
  </joint>

  <joint name="joint_3" type="continuous">
    <origin xyz="0.595 0 0" rpy="0 0 0" />
    <parent link="Link_2" />
    <child link="Link_3" />
    <axis xyz="0 0 1" />
    <limit lower="-3.05" upper="3.05" effort="8000" velocity="2.09" />
  </joint>

  <joint name="joint_4" type="continuous">
    <origin xyz="0.5715 0 -0.1315" rpy="0 0 0" />
    <parent link="Link_3" />
    <child link="Link_4" />
    <axis xyz="0 0 1" />
    <limit lower="-1.48" upper="4.62" effort="2000" velocity="3.14" />
  </joint>

  <joint name="joint_5" type="continuous">
    <origin xyz="0 -0.115 0" rpy="1.5708 0 0" />
    <parent link="Link_4" />
    <child link="Link_5" />
    <axis xyz="0 0 1" />
    <limit lower="-6.28" upper="6.28" effort="3000" velocity="3.14" />
  </joint>

  <joint name="joint_6" type="continuous">
    <origin xyz="0 0.1035 0" rpy="-1.5708 0 0" />
    <parent link="Link_5" />
    <child link="Link_6" />
    <axis xyz="0 0 1" />
    <limit lower="-6.28" upper="6.28" effort="1000" velocity="3.14" />
  </joint>

  <link name="tool0"/>
  <joint name="link6_to_tool0" type="fixed">
    <origin xyz="$(arg tool0_xyz)" rpy="$(arg tool0_rpy)" />
    <parent link="Link_6"/>
    <child link="tool0"/>
  </joint>

  <link name="$(arg legacy_tcp_frame)"/>
  <joint name="tool0_to_legacy_tcp" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="tool0"/>
    <child link="$(arg legacy_tcp_frame)"/>
  </joint>

  <link name="$(arg camera_frame)"/>
  <joint name="camera_mount_joint" type="fixed">
    <origin xyz="$(arg camera_xyz)" rpy="$(arg camera_rpy)" />
    <parent link="$(arg camera_parent)"/>
    <child link="$(arg camera_frame)"/>
  </joint>

</robot>
